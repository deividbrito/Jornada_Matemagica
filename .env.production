# URL pública da API em produção (Railway).
# Após criar o serviço da API no Railway, copie o domínio gerado (ex.:
# https://jornada-matemagica-api-production.up.railway.app) ou o domínio
# custom configurado e cole abaixo. Esse valor é embutido no bundle pelo
# Vite durante `npm run build` — não muda em runtime.
VITE_API_BASE_URL=https://SUA-API.up.railway.app
